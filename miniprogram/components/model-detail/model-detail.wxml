<view class="model-detail-mask" wx:if="{{show}}" bindtap="onMaskTap">
  <view class="model-detail-sheet" catchtap="onContentTap">
    <!-- 拖拽条 -->
    <view class="drag-handle"></view>

    <!-- 加载态 -->
    <view wx:if="{{loading}}" class="loading-state">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在获取模型信息...</text>
    </view>

    <!-- 错误态 -->
    <view wx:elif="{{error}}" class="empty-state">
      <text class="empty-icon">⚠️</text>
      <text class="empty-text">{{error}}</text>
    </view>

    <!-- 无匹配 -->
    <view wx:elif="{{!matchFound}}" class="empty-state">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">暂无详细信息</text>
      <text class="empty-hint">该模型暂未收录在 OpenRouter 中</text>
    </view>

    <!-- 模型详情 -->
    <view wx:else class="detail-content">
      <!-- 头部 -->
      <view class="detail-header">
        <view class="provider-badge">{{provider}}</view>
        <text class="detail-name">{{displayName}}</text>
      </view>

      <!-- 描述 -->
      <view class="detail-section">
        <scroll-view scroll-y class="description-scroll">
          <text class="description-text">{{description}}</text>
        </scroll-view>
      </view>

      <!-- 参数网格 -->
      <view class="spec-grid">
        <view class="spec-item">
          <text class="spec-label">上下文长度</text>
          <text class="spec-value">{{contextLength}}</text>
        </view>
        <view class="spec-item">
          <text class="spec-label">输入价格</text>
          <text class="spec-value spec-price">{{inputPrice}}</text>
        </view>
        <view class="spec-item">
          <text class="spec-label">输出价格</text>
          <text class="spec-value spec-price">{{outputPrice}}</text>
        </view>
        <view class="spec-item">
          <text class="spec-label">最大输出</text>
          <text class="spec-value">{{maxTokens}}</text>
        </view>
        <view class="spec-item">
          <text class="spec-label">模态</text>
          <text class="spec-value">{{modality}}</text>
        </view>
        <view class="spec-item">
          <text class="spec-label">知识截止</text>
          <text class="spec-value">{{knowledgeCutoff}}</text>
        </view>
      </view>

      <!-- 特性标签 -->
      <view wx:if="{{features.length > 0}}" class="features-section">
        <view wx:for="{{features}}" wx:key="*this" class="feature-tag">{{item}}</view>
      </view>

      <!-- OpenRouter 链接 -->
      <view class="openrouter-btn" bindtap="onOpenRouter">
        <text>在 OpenRouter 查看</text>
      </view>
    </view>
  </view>
</view>
