.model-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.model-detail-sheet {
  width: 100%;
  max-height: 75vh;
  background: linear-gradient(160deg, #1a1a3e 0%, #12122a 100%);
  border-radius: 36rpx 36rpx 0 0;
  padding: 20rpx 40rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drag-handle {
  width: 64rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  margin: 0 auto 30rpx;
}

/* 加载态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(100, 255, 218, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 详情内容 */
.detail-content {
  overflow-y: auto;
}

.detail-header {
  margin-bottom: 28rpx;
}

.provider-badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  background: rgba(100, 255, 218, 0.12);
  color: var(--accent);
  font-weight: 600;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  word-break: break-all;
}

/* 描述 */
.detail-section {
  margin-bottom: 28rpx;
}

.description-scroll {
  max-height: 200rpx;
}

.description-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  word-break: break-all;
}

/* 参数网格 */
.spec-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.spec-item {
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-md);
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.spec-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 8rpx;
}

.spec-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  word-break: break-all;
}

.spec-price {
  color: var(--accent);
}

/* 特性标签 */
.features-section {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.feature-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  background: rgba(100, 255, 218, 0.08);
  color: var(--accent);
  border: 1rpx solid rgba(100, 255, 218, 0.15);
}

/* 链接按钮 */
.link-btns {
  display: flex;
  gap: 16rpx;
}

.link-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, rgba(100, 255, 218, 0.15) 0%, rgba(100, 255, 218, 0.05) 100%);
  border: 1rpx solid rgba(100, 255, 218, 0.25);
  color: var(--accent);
  font-size: 28rpx;
  font-weight: 500;
}

.link-btn-secondary {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: var(--text-secondary);
}
