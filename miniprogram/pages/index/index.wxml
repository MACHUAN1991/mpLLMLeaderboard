<view class="container">
  <view class="header-row">
    <text class="title">全球AI大模型排名</text>
    <text class="admin-link" bindtap="goToAdmin">管理</text>
  </view>

  <view class="source-tabs">
    <view class="source-tab {{currentSource === 'all' ? 'active' : ''}}" data-source="all" bindtap="switchSource">全部</view>
    <view class="source-tab {{currentSource === 'arena' ? 'active' : ''}}" data-source="arena" bindtap="switchSource">Arena</view>
    <view class="source-tab {{currentSource === 'huggingface' ? 'active' : ''}}" data-source="huggingface" bindtap="switchSource">Hugging Face</view>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{empty}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无排名数据</text>
    <text class="empty-hint">管理员上传后将显示在这里</text>
  </view>

  <view wx:else class="record-list">
    <view wx:for="{{displayRecords}}" wx:key="recordId" class="record-card" data-recordid="{{item.recordId}}" data-date="{{item.date}}" bindtap="viewDetail">
      <view class="card-header">
        <view class="source-badge source-{{item.source}}">{{item.source === 'huggingface' ? 'HF' : 'Arena'}}</view>
        <text class="card-date">{{item.date}}</text>
        <view class="card-actions">
          <text class="card-count">{{item.totalModels}} 个模型</text>
          <text class="delete-btn" data-recordid="{{item.recordId}}" catchtap="deleteRecord">删除</text>
        </view>
      </view>

      <view class="top3-preview">
        <view wx:for="{{item.top3}}" wx:for-item="topItem" wx:for-index="idx" wx:key="rank" class="top-item top-{{idx + 1}}">
          <text class="top-rank">#{{topItem.rank}}</text>
          <text class="top-name">{{topItem.modelName}}</text>
        </view>
      </view>

      <view class="card-footer">
        <text class="card-time">{{formatDate(item.timestamp)}}</text>
        <text class="view-more">点击查看 →</text>
      </view>
    </view>
  </view>
</view>
