<view class="container">
  <view class="header-row">
    <view class="source-tabs">
      <view class="source-tab {{currentSource === 'artificial-analysis' ? 'active' : ''}}" data-source="artificial-analysis" bindtap="switchSource">Artificial Analysis</view>
      <view class="source-tab {{currentSource === 'arena' ? 'active' : ''}}" data-source="arena" bindtap="switchSource">Arena</view>
      <view class="source-tab {{currentSource === 'huggingface' ? 'active' : ''}}" data-source="huggingface" bindtap="switchSource">Hugging Face</view>
    </view>
  </view>
  <view class="source-desc" wx:if="{{currentSource === 'artificial-analysis'}}">
    <text>面向实际选型需求，按照智力进行排名，提供价格、速度、上下文长度等多维度信息</text>
    <text class="trend-link" bindtap="goTrend">查看趋势 →</text>
  </view>
  <view class="source-desc" wx:elif="{{currentSource === 'arena'}}">盲测对战平台，用户匿名提出问题，两个模型给出回答，用户匿名投票选出哪个模型回答更好，综合得分进行排名</view>
  <view class="source-desc" wx:elif="{{currentSource === 'huggingface'}}">开源模型SWE-Bench Pro榜单，基于企业级软件工程任务，评估各模型在真实复杂编程任务中的实战能力，进行得分排名</view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{empty}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无排名数据</text>
    <text class="empty-hint">管理员上传后将显示在这里</text>
  </view>

  <view wx:else class="record-list">
    <view wx:for="{{displayRecords}}" wx:key="recordId" class="record-card" data-recordid="{{item.recordId}}" data-date="{{item.date}}" bindtap="viewDetail">
      <view class="card-header">
        <view class="source-badge source-{{item.source}}">{{item.source === 'huggingface' ? 'HF' : item.source === 'artificial-analysis' ? 'AA' : 'Arena'}}</view>
        <text class="card-date">{{item.date}}</text>
        <view class="card-actions">
          <text class="card-count">{{item.totalModels}} 个模型</text>
        </view>
      </view>

      <view class="top3-preview">
        <view wx:for="{{item.top3}}" wx:for-item="topItem" wx:for-index="idx" wx:key="rank" class="top-item top-{{idx + 1}}">
          <text class="top-rank">#{{topItem.rank}}</text>
          <text class="top-name">{{topItem.modelName}}</text>
        </view>
      </view>

      <view class="card-footer">
        <text class="card-time">{{formatDate(item.timestamp)}}</text>
        <text class="view-more">点击查看 →</text>
      </view>
    </view>
  </view>

  <!-- 隐藏的管理入口：底部连续点击5次触发 -->
  <view class="secret-tap-area" bindtap="onSecretTap"></view>
</view>
