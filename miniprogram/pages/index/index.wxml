<view class="container container-{{currentSource}}">
  <view class="header-row">
    <view class="source-tabs">
      <view class="source-tab {{currentSource === 'agent' ? 'active active-cc' : ''}}" data-source="agent" bindtap="switchSource">Agent</view>
      <view class="source-tab {{currentSource === 'arena' ? 'active active-arena' : ''}}" data-source="arena" bindtap="switchSource">Arena</view>
      <view class="source-tab {{currentSource === 'artificial-analysis' ? 'active active-aa' : ''}}" data-source="artificial-analysis" bindtap="switchSource">Artificial Analysis</view>
      <view class="source-tab {{currentSource === 'huggingface' ? 'active active-hf' : ''}}" data-source="huggingface" bindtap="switchSource">Hugging Face</view>
    </view>
  </view>
  <view class="source-desc" wx:if="{{currentSource === 'artificial-analysis'}}">
    <text>面向实际选型需求，按照智力进行排名，提供价格、速度、上下文长度等多维度信息</text>
  </view>
  <view class="trend-btn-row" wx:if="{{currentSource === 'artificial-analysis'}}">
    <text class="trend-link trend-aa" bindtap="goTrend" data-source="artificial-analysis">查看排名变化趋势</text>
  </view>
  <view class="source-desc" wx:if="{{currentSource === 'arena'}}">
    <text>盲测对战平台，用户匿名提出问题，两个模型给出回答，用户匿名投票选出哪个模型回答更好，综合得分进行排名。</text>
    <text class="source-desc-sub">根据不同任务和模态，共设Text、Search、Vision等9个类型的排行榜</text>
  </view>
  <!-- Arena子分类（放在介绍下面） -->
  <view wx:if="{{currentSource === 'arena'}}" class="sub-category-row">
    <scroll-view scroll-x class="sub-category-tabs">
      <view wx:for="{{arenaSubCategories}}" wx:key="key" class="sub-category-tab {{currentSubCategory === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="switchSubCategory">{{item.label}}</view>
    </scroll-view>
  </view>
  <view class="trend-btn-row" wx:if="{{currentSource === 'arena'}}">
    <text class="trend-link trend-arena" bindtap="goTrend" data-source="arena">查看排名变化趋势</text>
  </view>
  <view class="source-desc" wx:if="{{currentSource === 'huggingface'}}">
    <text>开源模型SWE-Bench Pro榜单，基于企业级软件工程任务，评估各模型在真实复杂编程任务中的实战能力，进行得分排名</text>
  </view>
  <view class="trend-btn-row" wx:if="{{currentSource === 'huggingface'}}">
    <text class="trend-link trend-hf" bindtap="goTrend" data-source="huggingface">查看排名变化趋势</text>
  </view>
  <view class="source-desc" wx:if="{{currentSource === 'agent'}}">
    <text>各Agent实际使用的模型排行，基于OpenRouter平台的真实Token使用量数据</text>
  </view>
  <!-- Agent子分类（放在介绍下面） -->
  <view wx:if="{{currentSource === 'agent'}}" class="sub-category-row">
    <scroll-view scroll-x class="sub-category-tabs">
      <view wx:for="{{agentSubCategories}}" wx:key="key" class="sub-category-tab {{currentAgentType === item.key ? 'active-agent' : ''}}" data-key="{{item.key}}" bindtap="switchAgentType">{{item.label}}</view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{empty || (currentSource === 'agent' && agentLoaded && !agentRecord)}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无排名数据</text>
    <text class="empty-hint">管理员上传后将显示在这里</text>
  </view>

  <!-- 最新排名展示 -->
  <view wx:elif="{{!showHistory}}" class="latest-rankings">
    <view wx:if="{{rankingsLoading}}" class="loading">
      <text>加载排名中...</text>
    </view>
    <!-- Agent排名展示 -->
    <view wx:elif="{{currentSource === 'agent' && agentRecord}}" class="ranking-container gradient-card-cc">
      <view class="ranking-header">
        <text class="ranking-date source-color-cc">{{agentRecord.date}}</text>
        <text class="ranking-total-tokens">最近30天总Token: {{agentRecord.totalTokensFormatted}}</text>
      </view>
      <view class="ranking-list">
        <view wx:for="{{agentRankings}}" wx:key="rank" class="ranking-card {{item.rank === 1 ? 'gradient-card-gold' : item.rank === 2 ? 'gradient-card-purple' : item.rank === 3 ? 'gradient-card-blue' : 'gradient-card-normal'}}" bindtap="goAgentDetail" data-model="{{item.model}}" data-agent-type="{{currentAgentType}}">
          <view class="ranking-card-header">
            <view class="rank-badge rank-{{item.rank <= 3 ? item.rank : 'normal'}}">{{item.rank}}</view>
            <view class="ranking-model-info">
              <text class="ranking-model-name">{{item.modelName}}</text>
              <text class="ranking-model-org">{{item.provider}}</text>
            </view>
            <view class="ranking-model-stats">
              <text class="token-usage">{{item.totalTokensFormatted}}</text>
              <text class="token-percentage">{{item.percentage}}%</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <!-- 其他来源排名展示 -->
    <view wx:elif="{{latestRecord && currentSource !== 'agent'}}" class="ranking-container {{currentSource === 'artificial-analysis' ? 'gradient-card-purple' : currentSource === 'arena' ? 'gradient-card-amber' : 'gradient-card-blue'}}">
      <view class="ranking-header">
        <text class="ranking-date source-color-{{currentSource}}">{{latestRecord.date}}</text>
        <text class="tap-hint">点击模型查看详情</text>
      </view>
      <view class="ranking-list">
        <view wx:for="{{latestRankings}}" wx:key="rank" class="ranking-card {{item.rank === 1 ? 'gradient-card-gold' : item.rank === 2 ? 'gradient-card-purple' : item.rank === 3 ? 'gradient-card-blue' : 'gradient-card-normal'}}" bindtap="onModelTap" data-name="{{item.modelName}}">
          <view class="ranking-card-header">
            <view class="rank-badge rank-{{item.rank <= 3 ? item.rank : 'normal'}}">{{item.rank}}</view>
            <view class="ranking-model-info">
              <text class="ranking-model-name">{{item.modelName}}</text>
              <text class="ranking-model-org" wx:if="{{item.organization}}">{{item.organization}}</text>
            </view>
            <text class="ranking-model-score source-color-{{currentSource}}" wx:if="{{item.score}}">{{item.score}}</text>
          </view>
          <view class="ranking-card-details" wx:if="{{currentSource === 'artificial-analysis'}}">
            <view class="detail-item">
              <text class="detail-label">价格</text>
              <text class="detail-value detail-price">{{item.price || '-'}}</text>
            </view>
            <view class="detail-item">
              <text class="detail-label">速度</text>
              <text class="detail-value detail-speed">{{item.speed || '-'}}</text>
            </view>
            <view class="detail-item">
              <text class="detail-label">上下文</text>
              <text class="detail-value detail-context">{{item.contextLength || '-'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="empty-text">暂无排名数据</text>
    </view>
  </view>

  <!-- 隐藏的管理入口：底部连续点击5次触发 -->
  <view class="secret-tap-area" bindtap="onSecretTap"></view>

  <model-detail modelName="{{detailModelName}}" show="{{showModelDetail}}" bind:close="onCloseDetail" />
</view>
