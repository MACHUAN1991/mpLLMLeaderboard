/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  box-sizing: border-box;
}

.header-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  position: relative;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
}

.admin-link {
  position: absolute;
  right: 0;
  font-size: 24rpx;
  color: #64ffda;
  padding: 8rpx 20rpx;
  border: 1rpx solid #64ffda;
  border-radius: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #8892b0;
  margin-bottom: 24rpx;
  padding-left: 10rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #8892b0;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8892b0;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(100, 255, 218, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.source-badge {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.source-badge.source-arena {
  background: rgba(100, 255, 218, 0.2);
  color: #64ffda;
}

.source-badge.source-huggingface {
  background: rgba(255, 165, 0, 0.2);
  color: #ffa500;
}

.source-badge.source-artificial-analysis {
  background: rgba(138, 43, 226, 0.2);
  color: #9370db;
}

.card-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #64ffda;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: auto;
}

.card-count {
  font-size: 22rpx;
  color: #8892b0;
  background: rgba(100, 255, 218, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.delete-btn {
  font-size: 22rpx;
  color: #ff6b6b;
  padding: 6rpx 16rpx;
  border: 1rpx solid #ff6b6b;
  border-radius: 20rpx;
  opacity: 0.5;
}

.top3-preview {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.top-item {
  flex: 1;
  min-width: 0;  /* 允许收缩 */
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  text-align: center;
}

.top-1 {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.15) 0%, rgba(255, 215, 0, 0.05) 100%);
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

.top-2 {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.12) 0%, rgba(192, 192, 192, 0.03) 100%);
  border: 1rpx solid rgba(192, 192, 192, 0.25);
}

.top-3 {
  background: linear-gradient(135deg, rgba(205, 127, 50, 0.12) 0%, rgba(205, 127, 50, 0.03) 100%);
  border: 1rpx solid rgba(205, 127, 50, 0.25);
}

.top-rank {
  font-size: 24rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
  color: #fff;
}

.top-1 .top-rank { color: #ffd700; }
.top-2 .top-rank { color: #c0c0c0; }
.top-3 .top-rank { color: #cd7f32; }

.top-name {
  font-size: 24rpx;
  color: #fff;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-time {
  font-size: 20rpx;
  color: #8892b0;
}

.view-more {
  font-size: 22rpx;
  color: #64ffda;
}

/* 来源筛选标签 */
.source-tabs {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
}

.source-tabs::-webkit-scrollbar {
  display: none; /* Chrome/Safari */
}

.source-tab {
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8892b0;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.source-tab.active {
  color: #1a1a2e;
  background: #64ffda;
  border-color: #64ffda;
}

.source-desc {
  text-align: left;
  font-size: 24rpx;
  color: #8892b0;
  margin-bottom: 30rpx;
}