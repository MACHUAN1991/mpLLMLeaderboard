/* pages/index/index.wxss */

.header-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
}

.admin-link {
  position: absolute;
  right: 0;
  font-size: 22rpx;
  color: var(--accent);
  padding: 8rpx 24rpx;
  border: 1rpx solid var(--accent-border);
  border-radius: var(--radius-pill);
  background: var(--accent-bg);
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 来源筛选标签 */
.source-tabs {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 4rpx 0;
}

.source-tabs::-webkit-scrollbar {
  display: none;
}

.source-tab {
  padding: 14rpx 32rpx;
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.source-tab.active {
  color: #fff;
  font-weight: bold;
}

.active-aa {
  background: linear-gradient(135deg, var(--source-aa) 0%, #7c3aed 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 20rpx rgba(149, 117, 205, 0.4);
}

.active-arena {
  background: linear-gradient(135deg, var(--source-arena) 0%, #d4a843 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 20rpx rgba(201, 169, 110, 0.4);
}

.active-hf {
  background: linear-gradient(135deg, var(--source-hf) 0%, #3b82f6 100%);
  border-color: transparent;
  box-shadow: 0 4rpx 20rpx rgba(127, 179, 211, 0.4);
}

/* Arena子分类 */
.sub-category-row {
  margin-bottom: 20rpx;
}

.sub-category-tabs {
  display: flex;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.sub-category-tabs::-webkit-scrollbar {
  display: none;
}

.sub-category-tab {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.sub-category-tab.active {
  background: linear-gradient(135deg, var(--source-arena) 0%, #d4a843 100%);
  color: #fff;
  border-color: transparent;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(224, 151, 90, 0.3);
}

.source-desc {
  text-align: left;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-md);
  line-height: 1.6;
}

.source-desc-sub {
  display: block;
  margin-top: 8rpx;
}

.trend-btn-row {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24rpx;
}

.trend-link {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-pill);
}

.trend-aa {
  color: var(--source-aa);
  background: var(--source-aa-bg);
  border: 1rpx solid rgba(149, 117, 205, 0.25);
}

.trend-arena {
  color: var(--source-arena);
  background: var(--source-arena-bg);
  border: 1rpx solid rgba(201, 169, 110, 0.25);
}

.trend-hf {
  color: var(--source-hf);
  background: var(--source-hf-bg);
  border: 1rpx solid rgba(127, 179, 211, 0.25);
}

/* 隐藏的管理入口触发区域 */
.secret-tap-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  opacity: 0;
}

/* 最新排名展示区域 */
.latest-rankings {
  margin-top: 12rpx;
}

.ranking-container {
  border-radius: var(--radius-xl);
  padding: 28rpx;
}

.ranking-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.ranking-date {
  font-size: 28rpx;
  font-weight: bold;
}

.ranking-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.06);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-pill);
}

/* 卡片排名列表 */
.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-card {
  padding: 24rpx;
}

.ranking-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.ranking-card-header .rank-badge {
  width: 56rpx;
  height: 56rpx;
  font-size: 26rpx;
}

.ranking-model-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ranking-model-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ranking-model-org {
  font-size: 22rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ranking-model-score {
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

/* 分数渐变色 */
.score-gold {
  background: linear-gradient(135deg, var(--grad-gold-from) 0%, var(--grad-gold-to) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.score-purple {
  background: linear-gradient(135deg, var(--grad-purple-from) 0%, var(--grad-purple-to) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.score-blue {
  background: linear-gradient(135deg, var(--grad-blue-from) 0%, var(--grad-blue-to) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ranking-card-details {
  display: flex;
  gap: 12rpx;
  margin-top: 4rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 16rpx;
  background: rgba(0, 0, 0, 0.25);
  border-radius: var(--radius-sm);
  flex: 1;
  min-width: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.detail-item:first-child {
  flex: 1.5;
}

.detail-label {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.detail-value {
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.detail-price {
  color: var(--source-arena);
}

.detail-speed {
  color: var(--source-hf);
}

.detail-context {
  color: #14b8a6;
}
