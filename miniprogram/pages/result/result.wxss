/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  box-sizing: border-box;
}

.header {
  margin-bottom: 30rpx;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

/* 来源标签 */
.source-badge {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-weight: bold;
}

.source-badge.source-arena {
  background: rgba(100, 255, 218, 0.2);
  color: #64ffda;
}

.source-badge.source-huggingface {
  background: rgba(255, 165, 0, 0.2);
  color: #ffa500;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.date {
  font-size: 24rpx;
  color: #64ffda;
  background: rgba(100, 255, 218, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.header-actions {
  display: flex;
  justify-content: flex-end;
}

.stats {
  font-size: 22rpx;
  color: #8892b0;
  background: rgba(255, 255, 255, 0.05);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 25rpx;
  padding: 0 20rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  color: #fff;
  font-size: 26rpx;
}

.search-input::placeholder {
  color: #8892b0;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8892b0;
  font-size: 24rpx;
}

.filter-btn {
  width: 100rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 25rpx;
  color: #8892b0;
  font-size: 26rpx;
}

.filter-btn.active {
  background: #64ffda;
  color: #1a1a2e;
}

/* 筛选面板 */
.filter-panel {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(100, 255, 218, 0.2);
}

.filter-section {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-section:last-of-type {
  margin-bottom: 24rpx;
}

.filter-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #8892b0;
}

.picker-value {
  flex: 1;
  height: 70rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 24rpx;
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.btn-reset {
  background: transparent;
  border: 1rpx solid #8892b0;
  color: #8892b0;
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  border-radius: 20rpx;
}

.btn-apply {
  background: #64ffda;
  color: #1a1a2e;
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  border-radius: 20rpx;
}

/* 排名列表 */
.ranking-list {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  overflow-y: auto;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
  transition: all 0.2s;
}

.ranking-item:last-child {
  border-bottom: none;
}

.header-row {
  position: sticky;
  top: 0;
  background: rgba(100, 255, 218, 0.1);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  font-weight: bold;
  color: #64ffda;
  font-size: 22rpx;
}

.ranking-item.header-row .col-rank,
.ranking-item.header-row .col-model,
.ranking-item.header-row .col-org,
.ranking-item.header-row .col-score {
  color: #64ffda;
}

/* Top 3 样式 */
.ranking-item.top-1 {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.15) 0%, rgba(255, 215, 0, 0.05) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
  margin-bottom: 8rpx;
}

.ranking-item.top-2 {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.12) 0%, rgba(192, 192, 192, 0.03) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(192, 192, 192, 0.25);
  margin-bottom: 8rpx;
}

.ranking-item.top-3 {
  background: linear-gradient(135deg, rgba(205, 127, 50, 0.12) 0%, rgba(205, 127, 50, 0.03) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(205, 127, 50, 0.25);
  margin-bottom: 8rpx;
}

.rank-badge {
  width: 72rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
  background: rgba(255, 255, 255, 0.05);
  color: #8892b0;
  margin-right: 12rpx;
}

.rank-badge.badge-1 {
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  color: #1a1a2e;
  font-size: 24rpx;
}

.rank-badge.badge-2 {
  background: linear-gradient(135deg, #c0c0c0 0%, #a0a0a0 100%);
  color: #1a1a2e;
}

.rank-badge.badge-3 {
  background: linear-gradient(135deg, #cd7f32 0%, #a05a20 100%);
  color: #fff;
}

.col-rank {
  width: 72rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8892b0;
}

.col-model {
  flex: 1;
  color: #fff;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 10rpx;
}

.col-org {
  width: 110rpx;
  text-align: center;
  color: #a8b2d1;
  font-size: 20rpx;
}

.col-score {
  width: 90rpx;
  text-align: right;
  color: #8892b0;
  font-size: 24rpx;
  font-weight: 500;
}

.score-gold {
  color: #ffd700 !important;
  font-weight: bold;
}

.empty-filter {
  text-align: center;
  padding: 60rpx 0;
  color: #8892b0;
  font-size: 26rpx;
}

/* 原始数据 */
.raw-data {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.raw-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.raw-title {
  font-size: 22rpx;
  color: #8892b0;
}

.copy-btn {
  background: #64ffda;
  color: #1a1a2e;
  font-size: 20rpx;
  padding: 8rpx 20rpx;
  margin: 0;
}

.json-content {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8rpx;
  padding: 16rpx;
  max-height: 300rpx;
  overflow-y: scroll;
}

.json-content text {
  font-size: 18rpx;
  color: #a8b2d1;
  font-family: Monaco, Consolas, monospace;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
}

.btn-back {
  background: transparent;
  border: 2rpx solid #64ffda;
  color: #64ffda;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
