/* pages/result/result.wxss */

.header {
  margin-bottom: 24rpx;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.date {
  font-size: 24rpx;
  color: var(--accent);
  background: var(--accent-bg);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  border: 1rpx solid var(--accent-border);
}

.header-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
}

.export-btn {
  background: var(--accent-bg);
  color: var(--accent);
  font-size: 22rpx;
  padding: 10rpx 22rpx;
  border-radius: var(--radius-pill);
  border: 1rpx solid var(--accent-border);
}

.export-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 750px;
}

.stats {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.06);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-pill);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-pill);
  padding: 0 24rpx;
  height: 80rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  height: 80rpx;
  color: var(--text-primary);
  font-size: 26rpx;
}

.search-input::placeholder {
  color: var(--text-tertiary);
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.filter-btn {
  width: 100rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: var(--radius-pill);
  color: var(--text-secondary);
  font-size: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.filter-btn.active {
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(100, 255, 218, 0.3);
}

/* 筛选面板 */
.filter-panel {
  background: rgba(255, 255, 255, 0.04);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.filter-section {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-section:last-of-type {
  margin-bottom: 24rpx;
}

.filter-label {
  width: 120rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.picker-value {
  flex: 1;
  height: 70rpx;
  background: rgba(0, 0, 0, 0.25);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  color: var(--text-primary);
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.filter-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.btn-reset {
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  border-radius: var(--radius-pill);
}

.btn-apply {
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 30rpx;
  border-radius: var(--radius-pill);
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(100, 255, 218, 0.25);
}

/* 排名列表 */
.ranking-list {
  background: rgba(255, 255, 255, 0.02);
  border-radius: var(--radius-lg);
  padding: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.ranking-item {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  padding: 20rpx 14rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
}

.ranking-item:last-child {
  border-bottom: none;
}

.header-row {
  position: sticky;
  top: 0;
  background: rgba(100, 255, 218, 0.06);
  border-radius: var(--radius-sm);
  margin-bottom: 8rpx;
  font-weight: bold;
  color: var(--accent);
  font-size: 24rpx;
  border: 1rpx solid rgba(100, 255, 218, 0.1);
}

.ranking-item.header-row .col-rank,
.ranking-item.header-row .col-model,
.ranking-item.header-row .col-org,
.ranking-item.header-row .col-score {
  color: var(--accent);
}

.ranking-item.header-row .col-model {
  flex: 1;
  padding: 0 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Top 3 渐变行 */
.ranking-item.top-1 {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.12) 0%, rgba(255, 140, 0, 0.04) 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(255, 215, 0, 0.2);
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.08);
}

.ranking-item.top-2 {
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.1) 0%, rgba(124, 58, 237, 0.03) 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(168, 85, 247, 0.18);
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(168, 85, 247, 0.06);
}

.ranking-item.top-3 {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(6, 182, 212, 0.03) 100%);
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(59, 130, 246, 0.18);
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.06);
}

.rank-badge {
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.06);
  margin-right: 12rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.rank-badge.badge-1 {
  background: linear-gradient(135deg, var(--grad-gold-from) 0%, var(--grad-gold-to) 100%);
  color: #1a1a2e;
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.3);
}

.rank-badge.badge-2 {
  background: linear-gradient(135deg, var(--grad-purple-from) 0%, var(--grad-purple-to) 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(168, 85, 247, 0.3);
}

.rank-badge.badge-3 {
  background: linear-gradient(135deg, var(--grad-blue-from) 0%, var(--grad-blue-to) 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.col-rank {
  width: 72rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.col-model-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 10rpx;
  overflow: hidden;
}

.col-model {
  color: var(--text-primary);
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.col-model-extra {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.extra-price {
  font-size: 20rpx;
  color: var(--source-arena);
  width: 140rpx;
}

.extra-speed {
  font-size: 20rpx;
  color: var(--source-hf);
  width: 100rpx;
}

.extra-context {
  font-size: 20rpx;
  color: #14b8a6;
  width: 120rpx;
}

.col-org {
  width: 110rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.col-score {
  width: 90rpx;
  text-align: right;
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.score-gold {
  background: linear-gradient(135deg, var(--grad-gold-from) 0%, var(--grad-gold-to) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: bold;
}

.empty-filter {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

/* 原始数据 */
.raw-data {
  background: rgba(0, 0, 0, 0.3);
  border-radius: var(--radius-md);
  padding: 20rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.raw-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.raw-title {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.copy-btn {
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 20rpx;
  margin: 0;
  border-radius: var(--radius-pill);
  border: none;
}

.json-content {
  background: rgba(0, 0, 0, 0.25);
  border-radius: var(--radius-sm);
  padding: 16rpx;
  max-height: 300rpx;
  overflow-y: scroll;
}

.json-content text {
  font-size: 18rpx;
  color: var(--text-secondary);
  font-family: Monaco, Consolas, monospace;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
}
