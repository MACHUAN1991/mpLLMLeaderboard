/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  box-sizing: border-box;
}

.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.date {
  font-size: 26rpx;
  color: #64ffda;
}

.ranking-list {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  max-height: 800rpx;
  overflow-y: scroll;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 16rpx 10rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  font-size: 22rpx;
}

.ranking-item:last-child {
  border-bottom: none;
}

.header-row {
  background: rgba(100, 255, 218, 0.1);
  border-radius: 8rpx;
  font-weight: bold;
  color: #64ffda;
  position: sticky;
  top: 0;
}

.col-rank {
  width: 80rpx;
  text-align: center;
  color: #8892b0;
}

.col-model {
  flex: 1;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 10rpx;
}

.col-org {
  width: 120rpx;
  text-align: center;
  color: #a8b2d1;
  font-size: 20rpx;
}

.col-score {
  width: 100rpx;
  text-align: right;
  color: #8892b0;
}

.rank-top {
  color: #64ffda !important;
  font-weight: bold;
  font-size: 26rpx;
}

.score-top {
  color: #ffd700 !important;
  font-weight: bold;
}

.top-1 .col-rank {
  color: #ffd700 !important;
}

.top-2 .col-rank {
  color: #c0c0c0 !important;
}

.top-3 .col-rank {
  color: #cd7f32 !important;
}

.raw-data {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
}

.raw-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.raw-title {
  font-size: 24rpx;
  color: #8892b0;
}

.copy-btn {
  background: #64ffda;
  color: #1a1a2e;
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  margin: 0;
}

.json-content {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8rpx;
  padding: 20rpx;
  max-height: 400rpx;
  overflow-y: scroll;
}

.json-content text {
  font-size: 20rpx;
  color: #a8b2d1;
  font-family: Monaco, monospace;
  white-space: pre-wrap;
  word-break: break-all;
  display: block;
}

.btn-back {
  background: transparent;
  border: 2rpx solid #64ffda;
  color: #64ffda;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}
