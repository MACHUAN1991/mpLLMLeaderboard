<view class="container">
  <view class="header">
    <view class="header-top">
      <text class="title">排行榜</text>
      <view class="source-badge source-{{source}}">{{source === 'huggingface' ? 'HuggingFace' : source === 'artificial-analysis' ? 'AA' : 'Arena'}}</view>
      <text class="date">{{date}}</text>
    </view>
    <view class="header-actions">
      <text class="stats">{{stats.showing}} / {{stats.total}}</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索模型名称..."
        value="{{searchKey}}"
        bindinput="onSearch"
      />
      <view wx:if="{{searchKey}}" class="clear-btn" bindtap="onClearSearch">✕</view>
    </view>
    <view class="filter-btn {{showFilter ? 'active' : ''}}" bindtap="toggleFilter">
      <text>筛选</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view wx:if="{{showFilter}}" class="filter-panel">
    <view class="filter-section">
      <text class="filter-label">厂商</text>
      <picker mode="selector" range="{{orgPickerRange}}" bindchange="onFilterOrg">
        <view class="picker-value">
          {{filterOrg || '全部厂商'}}
        </view>
      </picker>
    </view>

    <view class="filter-section">
      <text class="filter-label">排名范围</text>
      <picker mode="selector" range="{{['全部', '前10名', '11-50名', '51-100名', '100+']}}" bindchange="onFilterRank">
        <view class="picker-value">
          {{rankRange === 'all' ? '全部' : rankRange}}
        </view>
      </picker>
    </view>

    <view class="filter-actions">
      <button class="btn-reset" bindtap="onResetFilter">重置</button>
      <button class="btn-apply" bindtap="toggleFilter">应用</button>
    </view>
  </view>

  <!-- 排名列表 -->
  <view class="ranking-list">
    <view class="ranking-item header-row">
      <view class="col-rank">排名</view>
      <view class="col-model">{{source === 'artificial-analysis' ? '模型（价格 / 速度）' : '模型'}}</view>
      <view class="col-org">厂商</view>
      <view class="col-score">{{source === 'artificial-analysis' ? '智力' : '分数'}}</view>
    </view>

    <view wx:for="{{filteredRankings}}" wx:key="rank" class="ranking-item {{item.rank <= 3 ? 'top-' + item.rank : ''}}">
      <view class="col-rank rank-badge {{item.rank <= 3 ? 'badge-' + item.rank : ''}}">#{{item.rank}}</view>
      <view class="col-model-wrap">
        <text class="col-model">{{item.modelName}}</text>
        <view wx:if="{{source === 'artificial-analysis'}}" class="col-model-extra">
          <text class="extra-price">{{item.price || '-'}}</text>
          <text class="extra-speed">{{item.speed || '-'}}</text>
        </view>
      </view>
      <view class="col-org">{{item.organization}}</view>
      <view class="col-score {{item.rank <= 3 ? 'score-gold' : ''}}">{{item.score}}</view>
    </view>

    <view wx:if="{{filteredRankings.length === 0}}" class="empty-filter">
      <text>没有符合条件的模型</text>
    </view>
  </view>

  <button class="btn-back" bindtap="goBack">返回</button>
</view>
