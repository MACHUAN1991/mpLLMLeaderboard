/* pages/admin/admin.wxss */
.container {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #8892b0;
}

/* 来源选择器 */
.source-selector {
  margin-bottom: 40rpx;
}

.selector-label {
  display: block;
  font-size: 24rpx;
  color: #8892b0;
  margin-bottom: 16rpx;
  text-align: center;
}

.source-tabs {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.source-tabs::-webkit-scrollbar {
  display: none;
}

.source-tab {
  padding: 16rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #8892b0;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.source-tab.active {
  color: #1a1a2e;
  background: #64ffda;
  border-color: #64ffda;
}

.upload-area {
  width: 100%;
  height: 500rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx dashed #64ffda;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.text {
  font-size: 28rpx;
  color: #64ffda;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.actions {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
  gap: 20rpx;
}

.btn-primary {
  background: #64ffda;
  color: #1a1a2e;
  font-weight: bold;
  border-radius: 12rpx;
  padding: 24rpx 60rpx;
  font-size: 30rpx;
}

.btn-secondary {
  background: transparent;
  color: #64ffda;
  border: 1rpx solid #64ffda;
  border-radius: 12rpx;
  padding: 20rpx 40rpx;
  font-size: 26rpx;
}

.result-preview {
  background: rgba(100, 255, 218, 0.1);
  border: 1rpx solid rgba(100, 255, 218, 0.3);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(100, 255, 218, 0.2);
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #64ffda;
}

.result-date {
  font-size: 24rpx;
  color: #8892b0;
}

.result-summary {
  text-align: center;
  margin-bottom: 24rpx;
}

.summary-item {
  font-size: 28rpx;
  color: #fff;
}

.result-actions {
  display: flex;
  justify-content: center;
}

.error-tip {
  background: rgba(255, 82, 82, 0.1);
  border: 1rpx solid #ff5252;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  color: #ff5252;
  text-align: center;
}

.tips {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 30rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  color: #64ffda;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #8892b0;
  line-height: 1.8;
}

/* 记录列表 */
.records-section {
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #64ffda;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.loading-text, .empty-text {
  text-align: center;
  color: #8892b0;
  font-size: 24rpx;
  padding: 30rpx 0;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.record-source {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.record-source.source-arena {
  background: rgba(100, 255, 218, 0.2);
  color: #64ffda;
}

.record-source.source-huggingface {
  background: rgba(255, 165, 0, 0.2);
  color: #ffa500;
}

.record-source.source-artificial-analysis {
  background: rgba(138, 43, 226, 0.2);
  color: #9370db;
}

.record-date {
  font-size: 24rpx;
  color: #fff;
}

.record-count {
  font-size: 22rpx;
  color: #8892b0;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff6b6b;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ff6b6b;
  border-radius: 16rpx;
}
