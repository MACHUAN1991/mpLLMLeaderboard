/* pages/admin/admin.wxss */

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 来源选择器 */
.source-selector {
  margin-bottom: 36rpx;
}

.selector-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  text-align: center;
}

.source-tabs {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.source-tabs::-webkit-scrollbar {
  display: none;
}

.source-tab {
  padding: 14rpx 30rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.source-tab.active {
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  border-color: transparent;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(100, 255, 218, 0.3);
}

/* Arena子分类 */
.sub-category-selector {
  margin-bottom: 36rpx;
}

.sub-category-tabs {
  display: flex;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.sub-category-tabs::-webkit-scrollbar {
  display: none;
}

.sub-category-tab {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.sub-category-tab.active {
  background: linear-gradient(135deg, var(--source-arena) 0%, #d4a843 100%);
  color: #fff;
  border-color: transparent;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(224, 151, 90, 0.3);
}

.upload-area {
  width: 100%;
  height: 500rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 2rpx dashed rgba(100, 255, 218, 0.3);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

.text {
  font-size: 28rpx;
  color: var(--accent);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.actions {
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
  gap: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  font-weight: bold;
  border-radius: var(--radius-pill);
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(100, 255, 218, 0.25);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: var(--accent);
  border: 1rpx solid var(--accent-border);
  border-radius: var(--radius-pill);
  padding: 20rpx 40rpx;
  font-size: 26rpx;
}

.result-preview {
  background: linear-gradient(135deg, rgba(100, 255, 218, 0.08) 0%, rgba(6, 182, 212, 0.04) 100%);
  border: 1rpx solid rgba(100, 255, 218, 0.18);
  border-radius: var(--radius-xl);
  padding: 30rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(100, 255, 218, 0.06);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(100, 255, 218, 0.12);
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--accent);
}

.result-date {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.result-summary {
  text-align: center;
  margin-bottom: 24rpx;
}

.summary-item {
  font-size: 28rpx;
  color: var(--text-primary);
}

.result-actions {
  display: flex;
  justify-content: center;
}

.error-tip {
  background: linear-gradient(135deg, rgba(255, 82, 82, 0.12) 0%, rgba(244, 63, 94, 0.06) 100%);
  border: 1rpx solid rgba(255, 82, 82, 0.25);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 36rpx;
  color: var(--danger);
  text-align: center;
}

.tips {
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tips-title {
  display: block;
  font-size: 26rpx;
  color: var(--accent);
  margin-bottom: 16rpx;
  font-weight: bold;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 记录列表 */
.records-section {
  margin-top: 36rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: bold;
  margin-bottom: 20rpx;
}

.loading-text, .empty-text {
  text-align: center;
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 30rpx 0;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.record-source {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-pill);
  font-weight: bold;
}

.record-source.source-arena {
  background: var(--source-arena-bg);
  color: var(--source-arena);
}

.record-source.source-huggingface {
  background: var(--source-hf-bg);
  color: var(--source-hf);
}

.record-source.source-artificial-analysis {
  background: var(--source-aa-bg);
  color: var(--source-aa);
}

.record-date {
  font-size: 24rpx;
  color: var(--text-primary);
}

.record-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.delete-btn {
  font-size: 24rpx;
  color: var(--danger);
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255, 82, 82, 0.25);
  border-radius: var(--radius-pill);
  background: rgba(255, 82, 82, 0.06);
}
