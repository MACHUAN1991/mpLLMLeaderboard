/* pages/admin/admin.wxss */

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 来源选择器 */
.source-selector {
  margin-bottom: 36rpx;
}

.selector-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  text-align: center;
}

.source-tabs {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.source-tabs::-webkit-scrollbar {
  display: none;
}

.source-tab {
  padding: 14rpx 30rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  flex-shrink: 0;
}

.source-tab.active {
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  border-color: transparent;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(100, 255, 218, 0.3);
}

/* Arena子分类 */
.sub-category-selector {
  margin-bottom: 36rpx;
}

.sub-category-tabs {
  display: flex;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}

.sub-category-tabs::-webkit-scrollbar {
  display: none;
}

.sub-category-tab {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.sub-category-tab.active {
  background: linear-gradient(135deg, var(--source-arena) 0%, #d4a843 100%);
  color: #fff;
  border-color: transparent;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(224, 151, 90, 0.3);
}

.upload-area {
  width: 100%;
  min-height: 200rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 2rpx dashed rgba(100, 255, 218, 0.3);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
  overflow: hidden;
  padding: 20rpx;
  box-sizing: border-box;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 40rpx 0;
}

.hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  opacity: 0.6;
  margin-top: 12rpx;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
  padding: 10rpx;
}

.image-item {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1;
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  border: 2rpx dashed rgba(100, 255, 218, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.03);
}

.add-icon {
  font-size: 60rpx;
  color: var(--accent);
  opacity: 0.5;
}

/* 图片标签 */
.image-labels {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 6rpx 4rpx;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.image-source-badge {
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-weight: bold;
  color: #fff;
}

.source-badge-arena {
  background: var(--source-arena);
}

.source-badge-artificial-analysis {
  background: var(--source-aa);
}

.source-badge-huggingface {
  background: var(--source-hf);
}

.image-sub-badge {
  font-size: 14rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
}

.image-sub-required {
  background: rgba(255, 82, 82, 0.7);
}

/* 子分类选择弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  width: 100%;
  background: #1a1a2e;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-title {
  text-align: center;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: bold;
  margin-bottom: 24rpx;
}

.picker-section-title {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.picker-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.picker-option {
  padding: 14rpx 28rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.picker-option.active {
  background: linear-gradient(135deg, var(--source-arena) 0%, #d4a843 100%);
  color: #fff;
  border-color: transparent;
  font-weight: bold;
}

.picker-done-row {
  margin-bottom: 20rpx;
}

.picker-done-btn {
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
  font-weight: bold;
}

.picker-cancel {
  text-align: center;
  padding: 20rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 批量进度 */
.batch-progress {
  text-align: center;
  margin-bottom: 24rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 4rpx;
  margin: 16rpx 0 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent) 0%, #06b6d4 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: var(--accent);
}

/* 批量结果汇总 */
.batch-summary {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-xl);
  padding: 30rpx;
  margin-bottom: 36rpx;
  text-align: center;
}

.summary-row {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 20rpx;
}

.summary-success {
  font-size: 28rpx;
  color: var(--accent);
  font-weight: bold;
}

.summary-fail {
  font-size: 28rpx;
  color: var(--danger);
  font-weight: bold;
}

.error-list {
  text-align: left;
  margin-bottom: 20rpx;
}

.error-item {
  display: block;
  font-size: 22rpx;
  color: var(--danger);
  padding: 6rpx 0;
  opacity: 0.8;
}

.icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

.text {
  font-size: 28rpx;
  color: var(--accent);
}

.actions {
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
  gap: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent) 0%, #06b6d4 100%);
  color: #fff;
  font-weight: bold;
  border-radius: var(--radius-pill);
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(100, 255, 218, 0.25);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  color: var(--accent);
  border: 1rpx solid var(--accent-border);
  border-radius: var(--radius-pill);
  padding: 20rpx 40rpx;
  font-size: 26rpx;
}

.result-preview {
  background: linear-gradient(135deg, rgba(100, 255, 218, 0.08) 0%, rgba(6, 182, 212, 0.04) 100%);
  border: 1rpx solid rgba(100, 255, 218, 0.18);
  border-radius: var(--radius-xl);
  padding: 30rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(100, 255, 218, 0.06);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(100, 255, 218, 0.12);
}

.result-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--accent);
}

.result-date {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.result-summary {
  text-align: center;
  margin-bottom: 24rpx;
}

.summary-item {
  font-size: 28rpx;
  color: var(--text-primary);
}

.result-actions {
  display: flex;
  justify-content: center;
}

.error-tip {
  background: linear-gradient(135deg, rgba(255, 82, 82, 0.12) 0%, rgba(244, 63, 94, 0.06) 100%);
  border: 1rpx solid rgba(255, 82, 82, 0.25);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 36rpx;
  color: var(--danger);
  text-align: center;
}

.tips {
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tips-title {
  display: block;
  font-size: 26rpx;
  color: var(--accent);
  margin-bottom: 16rpx;
  font-weight: bold;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 记录列表 */
.records-section {
  margin-top: 36rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

.batch-delete-toggle {
  font-size: 24rpx;
  color: var(--danger);
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(255, 82, 82, 0.25);
  border-radius: var(--radius-pill);
  background: rgba(255, 82, 82, 0.06);
}

.batch-delete-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.select-all-text {
  font-size: 24rpx;
  color: var(--accent);
}

.batch-delete-btn {
  font-size: 24rpx;
  color: #fff;
  padding: 8rpx 24rpx;
  background: var(--danger);
  border-radius: var(--radius-pill);
}

.record-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.record-checkbox.checked {
  background: var(--accent);
  border-color: var(--accent);
}

.loading-text, .empty-text {
  text-align: center;
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 30rpx 0;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.record-source {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-pill);
  font-weight: bold;
}

.record-source.source-arena {
  background: var(--source-arena-bg);
  color: var(--source-arena);
}

.record-source.source-huggingface {
  background: var(--source-hf-bg);
  color: var(--source-hf);
}

.record-source.source-artificial-analysis {
  background: var(--source-aa-bg);
  color: var(--source-aa);
}

.record-date {
  font-size: 24rpx;
  color: var(--text-primary);
}

.record-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.delete-btn {
  font-size: 24rpx;
  color: var(--danger);
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255, 82, 82, 0.25);
  border-radius: var(--radius-pill);
  background: rgba(255, 82, 82, 0.06);
}

/* Claude Code抓取区域 */
.cc-fetch-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.btn-cc-fetch {
  background: linear-gradient(135deg, var(--source-cc) 0%, #059669 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

.btn-cc-fetch[disabled] {
  opacity: 0.7;
}

.cc-fetch-result {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  padding: 16rpx;
  border-radius: var(--radius-md);
}

.cc-fetch-result.success {
  color: var(--accent);
  background: var(--accent-bg);
  border: 1rpx solid var(--accent-border);
}

.cc-fetch-result.error {
  color: var(--danger);
  background: var(--danger-bg);
  border: 1rpx solid rgba(255, 82, 82, 0.25);
}
