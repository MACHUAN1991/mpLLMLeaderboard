/* pages/trend/trend.wxss */

.header {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.subtitle-artificial-analysis { color: var(--source-aa); }
.subtitle-arena { color: var(--source-arena); }
.subtitle-huggingface { color: var(--source-hf); }

.loading, .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading text {
  color: var(--text-secondary);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 折线图区域 */
.chart-section {
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-hint {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.trend-canvas {
  width: 100%;
  border-radius: var(--radius-sm);
  background: rgba(0, 0, 0, 0.25);
}

/* 图例容器 */
.legend-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 14rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.legend-text {
  font-size: 20rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

/* 表格区域 */
.table-section {
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
}

/* 模型卡片 */
.model-card {
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.model-card.card-gold {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.12) 0%, rgba(255, 140, 0, 0.04) 100%);
  border-color: rgba(255, 215, 0, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.08);
}

.model-card.card-purple {
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.1) 0%, rgba(124, 58, 237, 0.03) 100%);
  border-color: rgba(168, 85, 247, 0.18);
  box-shadow: 0 4rpx 20rpx rgba(168, 85, 247, 0.06);
}

.model-card.card-blue {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(6, 182, 212, 0.03) 100%);
  border-color: rgba(59, 130, 246, 0.18);
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.06);
}

.model-card.card-normal {
  background: rgba(255, 255, 255, 0.03);
}

.model-card:last-child {
  margin-bottom: 0;
}

.model-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.model-rank-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.rank-badge-1 {
  background: linear-gradient(135deg, var(--grad-gold-from) 0%, var(--grad-gold-to) 100%);
  color: #1a1a2e;
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.3);
}

.rank-badge-2 {
  background: linear-gradient(135deg, var(--grad-purple-from) 0%, var(--grad-purple-to) 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(168, 85, 247, 0.3);
}

.rank-badge-3 {
  background: linear-gradient(135deg, var(--grad-blue-from) 0%, var(--grad-blue-to) 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.rank-badge-normal {
  background: rgba(255, 255, 255, 0.08);
  color: var(--text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.model-info {
  flex: 1;
  min-width: 0;
}

.model-name {
  display: block;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.model-org {
  display: block;
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.change-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  font-weight: bold;
}

.change-badge.rise {
  background: linear-gradient(135deg, rgba(100, 255, 218, 0.15) 0%, rgba(6, 182, 212, 0.08) 100%);
  color: var(--accent);
  border: 1rpx solid rgba(100, 255, 218, 0.2);
}

.change-badge.fall {
  background: linear-gradient(135deg, rgba(255, 82, 82, 0.15) 0%, rgba(244, 63, 94, 0.08) 100%);
  color: var(--danger);
  border: 1rpx solid rgba(255, 82, 82, 0.2);
}

.change-badge.same {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

/* 时间线 */
.rank-timeline {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  padding: 8rpx 0;
}

.rank-timeline::-webkit-scrollbar {
  display: none;
}

.timeline-point {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.point-rank {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.point-rank.rank-1 {
  background: linear-gradient(135deg, var(--grad-gold-from) 0%, var(--grad-gold-to) 100%);
  color: #1a1a2e;
  box-shadow: 0 0 12rpx rgba(255, 215, 0, 0.3);
}

.point-rank.rank-2 {
  background: linear-gradient(135deg, var(--grad-purple-from) 0%, var(--grad-purple-to) 100%);
  color: #fff;
  box-shadow: 0 0 12rpx rgba(168, 85, 247, 0.3);
}

.point-rank.rank-3 {
  background: linear-gradient(135deg, var(--grad-blue-from) 0%, var(--grad-blue-to) 100%);
  color: #fff;
  box-shadow: 0 0 12rpx rgba(59, 130, 246, 0.3);
}

.point-rank.rank-normal {
  background: rgba(255, 255, 255, 0.08);
  color: var(--text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.point-date {
  font-size: 18rpx;
  color: var(--text-secondary);
}

.point-score {
  font-size: 16rpx;
  color: var(--accent);
  margin-top: 4rpx;
}
