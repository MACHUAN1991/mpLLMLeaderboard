/* pages/history/history.wxss */
.container {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  box-sizing: border-box;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #8892b0;
  margin-top: 8rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #8892b0;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #8892b0;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(100, 255, 218, 0.1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.card-date {
  font-size: 28rpx;
  font-weight: bold;
  color: #64ffda;
}

.card-count {
  font-size: 22rpx;
  color: #8892b0;
  background: rgba(100, 255, 218, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.top3-preview {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.top-item {
  flex: 1;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}

.top-1 {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 215, 0, 0.05) 100%);
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

.top-2 {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.2) 0%, rgba(192, 192, 192, 0.05) 100%);
  border: 1rpx solid rgba(192, 192, 192, 0.3);
}

.top-3 {
  background: linear-gradient(135deg, rgba(205, 127, 50, 0.2) 0%, rgba(205, 127, 50, 0.05) 100%);
  border: 1rpx solid rgba(205, 127, 50, 0.3);
}

.top-rank {
  font-size: 24rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.top-1 .top-rank { color: #ffd700; }
.top-2 .top-rank { color: #c0c0c0; }
.top-3 .top-rank { color: #cd7f32; }

.top-name {
  font-size: 22rpx;
  color: #fff;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.top-org {
  font-size: 18rpx;
  color: #8892b0;
  display: block;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-time {
  font-size: 20rpx;
  color: #8892b0;
}

.delete-btn {
  font-size: 22rpx;
  color: #ff5252;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ff5252;
  border-radius: 8rpx;
}
