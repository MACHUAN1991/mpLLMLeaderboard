/* pages/history/history.wxss */

.header {
  margin-bottom: 36rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-secondary);
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  border-radius: var(--radius-xl);
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.card-date {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--accent);
}

.card-count {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.06);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
}

.top3-preview {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.top-item {
  flex: 1;
  border-radius: var(--radius-sm);
  padding: 16rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.top-1 {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.15) 0%, rgba(255, 140, 0, 0.05) 100%);
  border: 1rpx solid rgba(255, 215, 0, 0.25);
  box-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.08);
}

.top-2 {
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.12) 0%, rgba(124, 58, 237, 0.04) 100%);
  border: 1rpx solid rgba(168, 85, 247, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(168, 85, 247, 0.06);
}

.top-3 {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.12) 0%, rgba(6, 182, 212, 0.04) 100%);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.06);
}

.top-rank {
  font-size: 24rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.top-1 .top-rank {
  background: linear-gradient(135deg, var(--grad-gold-from) 0%, var(--grad-gold-to) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.top-2 .top-rank {
  background: linear-gradient(135deg, var(--grad-purple-from) 0%, var(--grad-purple-to) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.top-3 .top-rank {
  background: linear-gradient(135deg, var(--grad-blue-from) 0%, var(--grad-blue-to) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.top-name {
  font-size: 22rpx;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.top-org {
  font-size: 18rpx;
  color: var(--text-secondary);
  display: block;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-time {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.delete-btn {
  font-size: 22rpx;
  color: var(--danger);
  padding: 8rpx 20rpx;
  border: 1rpx solid rgba(255, 82, 82, 0.25);
  border-radius: var(--radius-pill);
  background: rgba(255, 82, 82, 0.06);
}
