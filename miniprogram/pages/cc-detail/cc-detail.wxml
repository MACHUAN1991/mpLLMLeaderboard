<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{modelData}}">
    <!-- 头部信息 -->
    <view class="detail-header">
      <view class="provider-badge">{{modelData.provider}}</view>
      <text class="model-name">{{modelData.modelName}}</text>
      <text class="model-id">{{modelData.model}}</text>
    </view>

    <!-- 使用统计 -->
    <view class="section">
      <text class="section-title">使用统计</text>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-label">Token使用量</text>
          <text class="stat-value">{{modelData.totalTokensFormatted}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">使用占比</text>
          <text class="stat-value stat-percentage">{{modelData.percentage}}%</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">排名</text>
          <text class="stat-value stat-rank">#{{modelData.rank}}</text>
        </view>
      </view>
    </view>

    <!-- OpenRouter信息 -->
    <view class="section" wx:if="{{openRouterInfo}}">
      <text class="section-title">模型信息（OpenRouter）</text>
      <view class="info-grid">
        <view class="info-item" wx:if="{{openRouterInfo.contextLength}}">
          <text class="info-label">上下文长度</text>
          <text class="info-value">{{openRouterInfo.contextLength}}</text>
        </view>
        <view class="info-item" wx:if="{{openRouterInfo.inputPrice}}">
          <text class="info-label">输入价格</text>
          <text class="info-value">{{openRouterInfo.inputPrice}}</text>
        </view>
        <view class="info-item" wx:if="{{openRouterInfo.outputPrice}}">
          <text class="info-label">输出价格</text>
          <text class="info-value">{{openRouterInfo.outputPrice}}</text>
        </view>
        <view class="info-item" wx:if="{{openRouterInfo.maxTokens}}">
          <text class="info-label">最大输出</text>
          <text class="info-value">{{openRouterInfo.maxTokens}}</text>
        </view>
        <view class="info-item" wx:if="{{openRouterInfo.modality}}">
          <text class="info-label">模态</text>
          <text class="info-value">{{openRouterInfo.modality}}</text>
        </view>
      </view>
      <view class="feature-tags" wx:if="{{openRouterInfo.features.length > 0}}">
        <text wx:for="{{openRouterInfo.features}}" wx:key="*this" class="feature-tag">{{item}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn-copy" bindtap="copyModelId">复制模型ID</button>
      <button class="btn-back" bindtap="goBack">返回</button>
    </view>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-state">
    <text class="error-text">{{error}}</text>
    <button class="btn-back" bindtap="goBack">返回</button>
  </view>
</view>
